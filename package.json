{
  "name": "pi-audit",
  "version": "0.4.13",
  "description": "Security review and compliance audit extension for Pi coding agents",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    }
  },
  "files": [
    "*.ts",
    "*.mjs",
    "src/**/*.ts",
    "README.md",
    "docs/",
    "skills/",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "keywords": [
    "pi",
    "coding-agent",
    "extension",
    "security",
    "audit",
    "review"
  ],
  "author": "BaphuongNA",
  "license": "MIT",
  "repository": "https://github.com/baphuongna/pi-audit",
  "dependencies": {
    "typebox": "^1.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0",
    "@earendil-works/pi-coding-agent": ">=0.73.0"
  },
  "scripts": {
    "postinstall": "node install.mjs"
  }
}
