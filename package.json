{
  "name": "@baphuongna/pi-audit",
  "version": "0.3.2",
  "description": "Pi extension for multi-perspective code review — security, performance, maintainability, testing, production readiness, diff analysis, review quality enforcement",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "pi",
    "coding-agent",
    "extension"
  ],
  "author": "BaphuongNA",
  "license": "MIT",
  "repository": "https://github.com/baphuongna/pi-audit",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsx --test",
    "typecheck": "tsc --noEmit"
  }
}
